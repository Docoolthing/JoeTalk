# Railway / Docker: set this exact variable on the *web* service (no trailing slash on the URL).
# REQUIRED at Docker build time — Railway passes it as BACKEND_BASE_URL for `mobile/Dockerfile`.
BACKEND_BASE_URL=https://jobtalk-api.up.railway.app
#
# Local Docker (PowerShell):
#   docker build --build-arg BACKEND_BASE_URL=https://jobtalk-api.up.railway.app -t joetalk-web .
#   docker run -p 8080:8080 -e PORT=8080 joetalk-web
#
# Local Flutter web:
#   flutter build web --release --dart-define=BACKEND_BASE_URL=https://jobtalk-api.up.railway.app
