# Railway / Docker: set this variable on the *web* service (runtime — container start).
# Injected into web/runtime-config.js by docker-entrypoint.sh (no Docker build-arg needed).
# Trailing `/` is fine; `normalizeBackendBaseUrl` in the client strips it before calling APIs.
BACKEND_BASE_URL=https://jobtalk-api.up.railway.app/
#
# Must be a literal `http(s)://…` URL. The entrypoint rejects empty values and
# Railway's `<UNKNOWN>` placeholder so the deploy fails fast instead of shipping
# a UI that shows `服務位址：<UNKNOWN>` and a backend that never responds.
#
# If you prefer a Railway service reference, use the form:
#   BACKEND_BASE_URL=https://${{api.RAILWAY_PUBLIC_DOMAIN}}
# where `api` matches the *exact* name of your API service in this project. A wrong
# service name is what produces `<UNKNOWN>` in `runtime-config.js`.
#
# Verify after deploy (browser or curl): https://<your-web-service>.up.railway.app/runtime-config.js
# Expect one line assigning globalThis.__JOETALK_BACKEND_BASE_URL__ to your HTTPS API URL.
# If you see `"<UNKNOWN>"` there, the value above is a broken Railway reference — fix it
# and redeploy the web service.
#
# Local Docker (PowerShell) — build needs no BACKEND_BASE_URL; runtime still requires it:
#   docker build -t joetalk-web .
#   docker run -p 8080:8080 -e PORT=8080 -e BACKEND_BASE_URL=https://jobtalk-api.up.railway.app/ joetalk-web
#
# Optional: bake URL at compile time as well:
#   docker build --build-arg BACKEND_BASE_URL=https://jobtalk-api.up.railway.app/ -t joetalk-web .
#
# Local Flutter web:
#   flutter build web --release --dart-define=BACKEND_BASE_URL=https://jobtalk-api.up.railway.app/
