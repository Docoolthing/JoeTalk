# Copy ideas into Railway *Variables* or local Docker build — not loaded by Flutter automatically.
#
# --- Web service (mobile / Flutter) ---
# REQUIRED at Docker build time (Railway passes this as a build ARG when the variable exists):
BACKEND_BASE_URL=https://YOUR-BACKEND-SERVICE.up.railway.app
#
# Build locally (after backend URL is known):
#   docker build --build-arg BACKEND_BASE_URL=%BACKEND_BASE_URL% -t joetalk-web .
#   docker run -p 8080:8080 -e PORT=8080 joetalk-web
#
# Flutter without Docker:
#   flutter build web --release --dart-define=BACKEND_BASE_URL=https://YOUR-BACKEND.up.railway.app
