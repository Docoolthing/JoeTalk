GEMINI_API_KEY=your_gemini_api_key_here
# Alternative name supported by @google/genai / AI Studio docs:
# GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# Optional (local): PORT for `npm run dev` only. On Railway, never set PORT — the platform assigns it.
# Optional (production): comma-separated origins allowed to call the API from a browser.
# Example: https://your-web-app.up.railway.app  (omit to allow any origin during dev)
# ALLOWED_ORIGINS=https://your-frontend.up.railway.app
# Optional: OpenRouter or any OpenAI-compatible /v1/chat/completions API.
# OPENROUTER_API_KEY=sk-or-v1-...
# Or use the same key name many OpenAI-compatible clients expect:
# OPENAI_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=google/gemini-2.5-flash
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
#
# Optional: cloud Text-to-Speech via OpenAI's /v1/audio/speech endpoint.
# This is OpenAI direct (NOT OpenRouter — OpenRouter doesn't proxy /v1/audio/speech).
# Without these, /api/tts returns 503 and the Flutter client silently falls back
# to on-device TTS (flutter_tts).
# OPENAI_TTS_API_KEY=sk-...                 # preferred; real OpenAI key
# # If unset, the server falls back to OPENAI_API_KEY (rejected if it's an OpenRouter sk-or-… key).
# OPENAI_TTS_MODEL=gpt-4o-mini-tts          # or `tts-1`, `tts-1-hd`
# OPENAI_TTS_VOICE=nova                     # alloy | ash | ballad | coral | echo | fable | nova | onyx | sage | shimmer | verse
# OPENAI_TTS_FORMAT=mp3                     # mp3 | wav | opus | aac | flac
#
# Railway (dashboard variables; do not commit):
# GEMINI_API_KEY / OPENROUTER_* / etc.
# ALLOWED_ORIGINS — Flutter web origin if you restrict CORS.
# Do not set PORT — health checks use your public https://…up.railway.app/health (no port in the URL).
